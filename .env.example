# Required
FOOTBALL_API_KEY=your_api_key_here

# MongoDB (defaults to local if not set)
MONGODB_URI=mongodb://localhost:27017

# Austerity tier: 1=lean(EPL+UCL), 2=+top5, 3=+europa (default: 3)
ACTIVE_TIER=3

# Season
SEASON=2025

# Intervals (seconds) — defaults shown
# INTERVAL_FULL_SWEEP=10800
# INTERVAL_CLOSING_24H=3600
# INTERVAL_CLOSING_6H=900
# INTERVAL_POLYMARKET=1800
# INTERVAL_FIXTURE_REFRESH=1800

# Budget
# DAILY_REQUEST_LIMIT=7500
# BUDGET_ALERT_PCT=0.80

# Logging
LOG_LEVEL=INFO
